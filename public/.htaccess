<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si el archivo o directorio existe físicamente, lo servimos
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f

    # Si no existe, redirige todo el tráfico a index.php pasando la ruta en la variable 'url'
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>