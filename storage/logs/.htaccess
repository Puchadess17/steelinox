# storage/logs/.htaccess

# ==========================================
# BLOQUEO DE ACCESO PÚBLICO (SEGURIDAD)
# ==========================================
# Prohíbe cualquier acceso directo a través 
# del navegador a los archivos de log.

<IfModule mod_authz_core.c>
    # Apache 2.4
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    # Apache 2.2
    Order deny,allow
    Deny from all
</IfModule>

# Deshabilitar listado de directorios por si acaso
Options -Indexes